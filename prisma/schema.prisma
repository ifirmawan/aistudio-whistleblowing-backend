datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Complaint {
  id               Int       @id @default(autoincrement())
  issue_code       String    @unique
  title            String
  content          String
  source_channel   String?
  agency           String?
  response_text    String?
  submitted_at_iso DateTime?
  detail_url       String?
  aiVerdict        AiVerdict?
}

model AiVerdict {
  id               Int       @id @default(autoincrement())
  complaintId      Int       @unique
  complaint        Complaint @relation(fields: [complaintId], references: [id])
  verdict          String
  is_bs            Boolean
  confidence_score Int
  red_flags        String    // Stored as JSON string
  explanation      String
}
